# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional
ANTHROPIC_MODEL=claude-3-7-sonnet-latest
STEEL_API_KEY=your_steel_api_key_here

# For local dev
# STEEL_BROWSER_API_URL=http://localhost:3000/v1
# STEEL_LOCAL_API_URL=http://localhost:3000/v1

STEEL_MONTY_LOCAL=false
STEEL_MONTY_API_URL=
STEEL_MONTY_MAX_ATTEMPTS=3
STEEL_MONTY_BROWSER_TIMEOUT_SEC=30
STEEL_MONTY_ARTIFACTS_DIR=artifacts/runs
STEEL_MONTY_LIMIT_MAX_DURATION_SECS=45
STEEL_MONTY_LIMIT_MAX_MEMORY=134217728
STEEL_MONTY_LIMIT_MAX_ALLOCATIONS=5000000
STEEL_MONTY_LIMIT_MAX_RECURSION_DEPTH=256
